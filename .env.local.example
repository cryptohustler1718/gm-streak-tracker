# ─── GM Streak Tracker — Environment Variables ───────────────────────────────
#
# Copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local

# Your deployed app URL (no trailing slash)
NEXT_PUBLIC_URL=https://your-app.vercel.app

# Farcaster manifest signature values
# Get these from: https://miniapps.farcaster.xyz/manifest-tool
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=
